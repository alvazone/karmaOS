# =============================================================================
# KarmaOS — Environment Variables (example)
# =============================================================================
# Copy this file to packages/db/.env and fill in real values.
# NEVER commit .env files with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# Used by: packages/db (Prisma CLI + client)
# Get yours at: https://console.neon.tech → Project → Connection details
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# -----------------------------------------------------------------------------
# Service ports (Sprint 1 — hardcoded in apps, documented here for reference)
# These will be wired via env vars in Docker Compose.
# -----------------------------------------------------------------------------
# API_PORT=3001    # apps/api (Express)
# WEB_PORT=3000    # apps/web (Next.js)
# AI_PORT=8000     # apps/ai (FastAPI)